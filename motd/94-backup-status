#!/usr/bin/env bash
# /etc/update-motd.d/94-backup-status
# Non-destructive MOTD fragment: shows full backup system status at login.
# Covers rsync mirrors AND restic compressed snapshots.
# Reads only from status log — no live rsync/restic at login time.
#
# Install: sudo cp motd/94-backup-status /etc/update-motd.d/ && \
#          sudo chmod +x /etc/update-motd.d/94-backup-status

STATUS_LOG="/var/log/backup-wizard/last_run.log"
RESTIC_BIN="/usr/local/bin/restic"
RESTIC_PASS="/home/jeb/.config/backup-wizard/restic_password"
RESTIC_REPO_BASE="/mnt/hitachi_2tb/restic_repos"

BOLD='\033[1m'; CYAN='\033[0;36m'; GREEN='\033[0;32m'
YELLOW='\033[1;33m'; RED='\033[0;31m'; MAGENTA='\033[0;35m'
BLUE='\033[0;34m'; RESET='\033[0m'

# ---------------------------------------------------------------------------
# Helper: render one section of the status log filtered by tag prefix
# ---------------------------------------------------------------------------
print_log_section() {
    local prefix="$1"   # e.g. "RSYNC:" or "RESTIC:"
    local found=0
    declare -A seen
    while IFS= read -r line; do
        tag=$(echo "$line" | grep -oP '\[[^\]]+\]' | head -1)
        [[ "$tag" != *"${prefix}"* ]] && continue
        if [[ -n "$tag" && -z "${seen[$tag]+x}" ]]; then
            seen["$tag"]=1
            # skip housekeeping entries (init, prune) — show backup ops only
            short_check=$(echo "$tag" | sed "s/\[${prefix}//;s/\]//")
            [[ "$short_check" == "init" || "$short_check" == "prune" ]] && continue
            found=1
            status=$(echo "$line" | grep -oP 'OK|WARN|FAILED' | head -1)
            case "$status" in
                OK)     icon="${GREEN}✓${RESET}" ;;
                WARN)   icon="${YELLOW}⚠${RESET}" ;;
                FAILED) icon="${RED}✗${RESET}"   ;;
                *)      icon=" "                  ;;
            esac
            ts=$(echo "$line" | awk '{print $1, $2}')
            # strip tag prefix to shorten label: RSYNC:AI-ML-Papers → AI-ML-Papers
            short=$(echo "$tag" | sed "s/\[${prefix}//;s/\]//")
            msg=$(echo "$line" | sed 's/^[^ ]* [^ ]* *\[[^\]]*\] *//' | cut -c1-60)
            printf "    %b  %-22s  %s\n" "$icon" "$short" "$ts"
        fi
    done < <(sort -r "$STATUS_LOG")
    [[ $found -eq 0 ]] && echo -e "    ${YELLOW}none recorded yet${RESET}"
}

echo ""
echo -e "${BOLD}${CYAN}━━━━  Backup System (backup-wizard)  ━━━━━━━━━━━━━━━━━━━━━${RESET}"

# ---------------------------------------------------------------------------
# Section 1: Rsync mirrors
# ---------------------------------------------------------------------------
if [[ -f "$STATUS_LOG" && -s "$STATUS_LOG" ]]; then
    echo -e "  ${BOLD}${BLUE}Rsync mirrors${RESET}  (plain browsable copies)"
    print_log_section "RSYNC:"

    echo ""
    echo -e "  ${BOLD}${MAGENTA}Restic snapshots${RESET}  (encrypted · zstd · versioned)"
    print_log_section "RESTIC:"
else
    echo -e "  ${YELLOW}No backup runs recorded yet.${RESET}  Run: backup-wizard"
fi

# ---------------------------------------------------------------------------
# Section 2: Restic repo snapshot counts (quick live check, very fast)
# ---------------------------------------------------------------------------
if [[ -x "$RESTIC_BIN" && -f "$RESTIC_PASS" && -d "$RESTIC_REPO_BASE" ]]; then
    echo ""
    echo -e "  ${BOLD}${MAGENTA}Restic repos${RESET}  (${RESTIC_REPO_BASE})"
    for repo_dir in "${RESTIC_REPO_BASE}"/*/; do
        [[ -d "$repo_dir" ]] || continue
        name=$(basename "$repo_dir")
        if [[ -f "${repo_dir}config" ]]; then
            snap_out=$(RESTIC_PASSWORD_FILE="$RESTIC_PASS" \
                       "$RESTIC_BIN" -r "$repo_dir" snapshots 2>/dev/null)
            count=$(echo "$snap_out" | grep -c '^[0-9a-f]\{8\}' || echo "?")
            latest=$(echo "$snap_out" | awk '/^[0-9a-f]{8}/{ts=$2" "$3} END{print ts}')
            printf "    ${MAGENTA}→${RESET}  %-22s  %s snapshot(s)  latest: %s\n" \
                   "$name" "$count" "${latest:-unknown}"
        else
            printf "    ${YELLOW}⚠${RESET}  %-22s  (not initialized)\n" "$name"
        fi
    done
fi

# ---------------------------------------------------------------------------
# Section 3: Mount health
# ---------------------------------------------------------------------------
echo ""
echo -e "  ${BOLD}Backup destinations:${RESET}"
declare -A MOUNT_LABELS=(
    ["/mnt/hitachi_2tb"]="Hitachi 2TB  rsync mirrors + restic repos"
    ["/mnt/pdf_backup"]="SDA ext4     PDF archive rsync backup"
    ["/mnt/raid0"]="RAID0        PDF archive source (~4.7T)"
)
for mp in "/mnt/hitachi_2tb" "/mnt/pdf_backup" "/mnt/raid0"; do
    label="${MOUNT_LABELS[$mp]}"
    if mountpoint -q "$mp" 2>/dev/null; then
        free=$(df -h "$mp" 2>/dev/null | awk 'NR==2{print $4}')
        used=$(df -h "$mp" 2>/dev/null | awk 'NR==2{print $5}')
        echo -e "    ${GREEN}✓${RESET}  ${mp}  ${label}  — free: ${free}  (${used} used)"
    else
        echo -e "    ${RED}✗${RESET}  ${mp}  ${label}  — NOT MOUNTED"
    fi
done

# ---------------------------------------------------------------------------
# Section 4: Quick reference
# ---------------------------------------------------------------------------
echo ""
echo -e "  ${BOLD}Quick commands:${RESET}"
echo -e "    ${CYAN}backup-wizard${RESET}                  interactive menu"
echo -e "    ${CYAN}backup-wizard --all-archives${RESET}   rsync all 3 paper archives"
echo -e "    ${CYAN}backup-wizard --all-restic${RESET}     restic snapshot all 3 archives"
echo -e "    ${CYAN}backup-wizard --status${RESET}         full status report"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
echo ""
